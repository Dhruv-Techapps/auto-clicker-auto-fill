{
  "name": "acf-options-page",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/acf-options-page/src",
  "projectType": "application",
  "tags": ["scope:apps"],
  "// targets": "to see all targets run: nx show project acf-options-page --web",
  "targets": {
    "dev": {
      "dependsOn": [
        {
          "projects": ["acf-extension"],
          "target": "serve"
        }
      ]
    },
    "e2e": {
      "dependsOn": [
        {
          "projects": ["acf-common"],
          "target": "build",
          "params": "ignore"
        }
      ],
      "configurations": {
        "development": {
          "envFile": ".env.development"
        },
        "production": {
          "envFile": ".env.production"
        }
      }
    }
  }
}
