{
  "name": "acf-options-page",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/acf-options-page/src",
  "projectType": "application",
  "tags": ["scope:apps"],
  "// targets": "to see all targets run: nx show project acf-options-page --web",
  "targets": {
    "build": {
      "inputs": [
        "production",
        "^production",
        { "env": "VITE_PUBLIC_VARIANT" },
        { "env": "VITE_PUBLIC_CHROME_EXTENSION_ID" },
        { "env": "VITE_PUBLIC_I18N" },
        { "env": "VITE_PUBLIC_URL" },
        { "env": "VITE_PUBLIC_GOOGLE_ADS_SLOT" },
        { "env": "VITE_PUBLIC_GOOGLE_ADS_CLIENT" },
        { "env": "VITE_PUBLIC_FIREBASE_API_KEY" },
        { "env": "VITE_PUBLIC_FIREBASE_DATABASE_URL" },
        { "env": "VITE_PUBLIC_FIREBASE_PROJECT_ID" },
        { "env": "VITE_PUBLIC_FIREBASE_BUCKET" },
        { "env": "VITE_PUBLIC_RELEASE_VERSION" },
        { "env": "VITE_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT" },
        { "env": "VITE_PUBLIC_OTEL_EXPORTER_OTLP_TOKEN" }
      ]
    },
    "dev": {
      "dependsOn": [
        {
          "projects": ["acf-extension"],
          "target": "serve"
        }
      ]
    },
    "e2e": {
      "dependsOn": [
        {
          "projects": ["acf-common"],
          "target": "build",
          "params": "ignore"
        }
      ],
      "configurations": {
        "development": {
          "envFile": ".env.development"
        },
        "production": {
          "envFile": ".env.production"
        }
      }
    }
  }
}
